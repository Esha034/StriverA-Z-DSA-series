class Solution:
    def largestElement(self, nums):
        n=len(nums)
        max=nums[0]
        for i in range(1,n):
            if nums[i]>max:
                max=nums[i]
        return max
n=int(input().strip())
nums=list(map(int,input().split()))
obj=Solution()
result=obj.largestElement(nums)
print(result)
