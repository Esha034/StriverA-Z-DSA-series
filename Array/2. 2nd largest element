#optimal
class Solution:
    def secondLargestElement(self, nums):
        max1 = float('-inf')
        max2 = float('-inf')

        for num in nums:
            if num > max1:
                max2 = max1
                max1 = num
            elif num > max2 and num != max1:
                max2 = num

        return max2




#better
class Solution:
    def secondLargestElement(self, nums):
        max1 = max(nums)
        max2 = float('-inf')

        for num in nums:
            if num != max1 and num > max2:
                max2 = num

        if max2 == float('-inf'):
            return -1

        return max2




#bruteforce
class Solution:
    def secondLargestElement(self, nums):
        nums.sort()
        largest = nums[-1]

        for i in range(len(nums)-2, -1, -1):
            if nums[i] != largest:
                return nums[i]

        return -1
