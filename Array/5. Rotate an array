class Solution:
    def rotate(self, nums: List[int], k: int) -> None:
        n=len(nums)
        k=k%n
    
        def revarray(l,r):
            while l<r:
                nums[l],nums[r]=nums[r],nums[l]
                l+=1
                r-=1

        revarray(0,n-1)
        revarray(0,k-1)
        revarray(k,n-1)

        
        
        
#better      
        n=len(nums)
        temp=[0]*n
        for i in range(n):
            temp[(i+k)%n]=nums[i]
        for i in range(n):
            nums[i]=temp[i]


        
#bruteforce
        n=len(nums)
        for _ in range(k):
            last=nums[-1]
            for i in range(n-1,0,-1):
                nums[i]=nums[i-1]
            nums[0]=last
        return nums





        
